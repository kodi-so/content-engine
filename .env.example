# Convex browser-visible URLs
# Run `npm run convex:dev` first if you need Convex to create/link your dev deployment.
VITE_CONVEX_URL=your_convex_deployment_url_here
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Convex local deployment selector
# Created by `npm run convex:dev`; keep this local and deployment-specific.
# CONVEX_DEPLOYMENT=dev:your-deployment-name

# Clerk Authentication
# Get these from https://dashboard.clerk.com/
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Clerk JWT Issuer Domain (for Convex auth)
# Format: https://your-app.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-domain.clerk.accounts.dev

# Private beta access gate (server-side Convex env var)
BETA_ACCESS_EMAILS=teammate@example.com,you@example.com

# OpenRouter (server-side Convex env var for Create agent planning/text)
OPENROUTER_API_KEY=sk-or-v1-your_api_key_here
# Optional override; defaults to https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# fal.ai (server-side Convex env var for default media generation)
FAL_API_KEY=your_fal_api_key_here
# Optional override; defaults to https://queue.fal.run
FAL_QUEUE_BASE_URL=https://queue.fal.run

# Google Gemini (server-side Convex env var for video analysis and optional generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Analyze social URL resolver (server-side Convex env vars)
MEDIA_RESOLVER_URL=https://your-media-resolver.railway.app
MEDIA_RESOLVER_API_KEY=replace_with_a_shared_secret

# Cloudflare R2 media storage (server-side Convex env vars)
# Create an R2 bucket and an API token, then set these in your Convex deployment.
# Endpoint format: https://<account_id>.r2.cloudflarestorage.com
R2_TOKEN=your_r2_api_token_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=your_r2_bucket_name
# Public base URL that serves objects from the bucket. Use a custom domain bound
# to the bucket, or enable the bucket's public r2.dev URL. No trailing slash.
R2_PUBLIC_URL=https://media.your-domain.com

# Studio server-side render worker (server-side Convex env vars)
STUDIO_RENDER_WORKER_URL=https://your-studio-render-worker.railway.app
STUDIO_RENDER_WORKER_API_KEY=replace_with_a_shared_secret
# Optional override; defaults to CONVEX_SITE_URL when omitted.
STUDIO_RENDER_CALLBACK_URL=https://your-deployment.convex.site
# Optional separate callback secret; defaults to STUDIO_RENDER_WORKER_API_KEY.
STUDIO_RENDER_CALLBACK_API_KEY=replace_with_a_shared_secret

# BulkAPIs (server-side only; do not expose with a VITE_ prefix)
BULKAPIS_API_KEY=bulk_ak_your_api_key_here
# Optional override; defaults to https://bulkapis.com/api/v1
BULKAPIS_BASE_URL=https://bulkapis.com/api/v1

# PostBridge publishing (server-side only; do not expose with a VITE_ prefix)
POSTBRIDGE_API_KEY=your_postbridge_api_key_here
# Optional override; defaults to https://api.post-bridge.com/v1
POSTBRIDGE_BASE_URL=https://api.post-bridge.com/v1

# TikTok API (for OAuth and posting)
# Get these from https://developers.tiktok.com/
# Backend (Convex) - set these in Convex dashboard
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
# Frontend - for building OAuth URL
VITE_TIKTOK_CLIENT_KEY=your_tiktok_client_key_here

# Convex Site URL (for HTTP endpoints/OAuth callbacks)
# Get this from your Convex dashboard - it's your deployment's HTTP endpoint URL
# Format: https://your-deployment.convex.site
CONVEX_SITE_URL=https://your-deployment.convex.site

# Frontend URL (for OAuth redirects back to your app)
# Development: http://localhost:5173
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173
